# API Configuration
# Production web/mobile API URL. Defaults to https://api.health-hera.com/api when omitted.
EXPO_PUBLIC_API_URL=https://api.health-hera.com/api

# Local development API URL. Defaults to http://localhost:3000/api when omitted.
EXPO_PUBLIC_API_URL_DEV=http://localhost:3000/api

# Google Maps Configuration
# Get your key from: https://console.cloud.google.com/
# Required APIs: Places API, Maps Static API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Auth (Sign in with Google)
# OAuth Web Client ID from Google Cloud Console.
EXPO_PUBLIC_GOOGLE_AUTH_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
